DATABASE_URL=postgresql://user:pass@localhost:5432/tokenomicon

# App URL — used for Stripe redirect URLs and sitemap. No trailing slash.
NEXT_PUBLIC_APP_URL=https://tokenomicon.io

# Clerk — get from clerk.com dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/arena
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/arena

# Stripe — get from stripe.com dashboard
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe recurring subscription Price IDs
# How to create them:
#   1. stripe.com/dashboard → Products → Add product
#   2. "Dev Plan" → Recurring → $15.00 / month → Save → copy Price ID (price_1...)
#   3. "Pro Plan" → Recurring → $49.00 / month → Save → copy Price ID
#   4. Paste both below
# Then register the webhook endpoint:
#   stripe.com/dashboard → Developers → Webhooks → Add endpoint
#   URL: https://yourdomain.com/api/billing/webhook
#   Events: checkout.session.completed, invoice.payment_succeeded,
#            invoice.payment_failed, charge.refunded,
#            customer.subscription.deleted, customer.subscription.updated
#   Copy the Signing Secret → STRIPE_WEBHOOK_SECRET above
# For local dev: run `npm run dev:stripe` in a second terminal (requires Stripe CLI)
STRIPE_PRICE_DEV_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# AI Provider API Keys — set whichever providers you want to activate
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Admin access — comma-separated email addresses
TOKENOMICON_ADMIN_EMAILS=founder@example.com

# Arcade compliance — chance games (Token Mines, Prompt Crash) kill-switch.
# Set to "false" to disable the two luck-based games globally for a deploy while
# leaving every skill game and the API product fully available. Default: enabled.
ARCADE_CHANCE_GAMES_ENABLED=true

# Email (Resend) — used for budget alerts and notifications
# Get from resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Vercel Cron auth — set to a long random secret and add to vercel.json cron config
# Generate: openssl rand -hex 32
CRON_SECRET=

# Optional
# NODE_ENV=production
# UNSPLASH_ACCESS_KEY=   # unused; image deepfake path is disabled
